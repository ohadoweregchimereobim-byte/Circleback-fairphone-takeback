        <condition/>
        <description>Computes reward_code (CB-REWARD- + first 5 chars of processing_job sys_id), issue_date (now), and expiry_date (90 days from issue) on new Reward Fulfilment records.</description>
        <execute_function>false</execute_function>
        <filter_condition/>
        <is_rest>false</is_rest>
        <message/>
        <name>CircleBack Reward Setup</name>
        <order>100</order>
        <priority>100</priority>
        <rest_method/>
        <rest_method_text/>
        <rest_service/>
        <rest_service_text/>
        <rest_variables/>
        <role_conditions/>
        <script><![CDATA[
    (function executeRule(current, previous) {
      // 1. Set issue_date to now
      var now = new GlideDateTime();
      current.setValue('issue_date', now);

      // 2. Compute expiry_date as 90 days from now
      var expiry = new GlideDateTime();
      expiry.addDaysUTC(90);
      current.setValue('expiry_date', expiry);

      // 3. Generate reward_code from processing_job sys_id
      var jobSysId = current.getValue('processing_job') || '';
      var shortId = jobSysId.substring(0, 5).toUpperCase();
      current.setValue('reward_code', 'CB-REWARD-' + shortId);
    })(current, previous);
  ]]></script>
